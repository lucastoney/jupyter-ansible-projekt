Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"
  config.vm.hostname = "jupyter-node"

  config.vm.define "jupyter-node" do |node|
    node.vm.network "private_network", ip: "192.168.56.20"

    if ENV["PRUEFUNG_SSH"] == "1"
      pruefung_host_ip = ENV["PRUEFUNG_HOST_IP"]
      if pruefung_host_ip.nil? || pruefung_host_ip.empty?
        raise "PRUEFUNG_HOST_IP muss auf die LAN-IP des Laptops gesetzt sein."
      end

      node.vm.network "forwarded_port",
        guest: 22,
        host: 2223,
        host_ip: pruefung_host_ip,
        protocol: "tcp",
        id: "pruefung_ssh"
    end

    node.vm.provider "virtualbox" do |vb|
      vb.name = "jupyter-node"
      vb.memory = 2048
      vb.cpus = 2
    end
  end
end
